{
  "name": "sikka",
  "version": "0.1.0",
  "description": "A zero-dependency, runtime-agnostic template engine with Astro-like syntax.",
  "keywords": [
    "template",
    "engine",
    "html",
    "astro",
    "ssr",
    "compiler",
    "render",
    "sikka"
  ],
  "author": "Rasheed Qaied <wusaby.rush@zohomail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ws-rush/sikka/issues"
  },
  "homepage": "https://github.com/ws-rush/sikka#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ws-rush/sikka.git"
  },
  "files": [
    "dist",
    "README.md",
    "README.astro-syntax.md",
    "CHANGELOG.md",
    "jsr.json",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release": "node scripts/release.cjs",
    "bench": "node bench/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "globals": "^17.4.0",
    "knip": "^6.3.1",
    "prettier": "^3.8.2",
    "chalk": "^5.3.0",
    "conventional-changelog-cli": "^4.1.0",
    "enquirer": "^2.4.1",
    "execa": "^8.0.1",
    "semver": "^7.5.4",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
