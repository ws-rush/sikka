<!DOCTYPE html>
<html>
<head>
    <title><%= it.title %></title>
</head>
<body>
    <h1><%= it.title %></h1>
    <% if (it.items.length > 0) { %>
        <ul>
            <% it.items.forEach(function(item) { %>
                <%~ include("./item", { item: item }) %>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No items found.</p>
    <% } %>
</body>
</html>
